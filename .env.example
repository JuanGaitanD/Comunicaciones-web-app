# Supabase: backend (Auth + Postgres + Realtime). Ver docs/01-supabase-bootstrap.md
# Copiar este archivo a .env.local y rellenar con los valores del dashboard de Supabase
# (Project Settings → API).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TURN: relay para WebRTC cuando STUN no logra atravesar NAT simétrico (típico
# en ISPs latinoamericanos con CGNAT). Sin esto, llamadas entre redes
# restrictivas se quedan sin audio. Ver docs/05-callroom-and-webrtc.md.
# Free tier: https://www.metered.ca/tools/openrelay/ (crear cuenta y copiar
# las credenciales del dashboard).
# La URL TLS sobre 443 se usa como fallback cuando la red bloquea UDP.
VITE_TURN_URL=
VITE_TURN_URL_TLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
